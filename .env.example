APP_NAME="Contact Manager"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- SQLite ---
DB_CONNECTION=sqlite
# Leave DB_DATABASE unset to use database/database.sqlite by default.

# Keep infra simple: no extra DB tables needed for these.
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

VITE_APP_NAME="${APP_NAME}"
